/* ========================================
   暗色科技蓝配色方案
   主色: #4a90d9 | 深色背景: #1e1e2e
   ======================================== */

/* --- 链接 --- */
a, a:hover {
  color: #4a90d9;
}
.post-body a:hover {
  border-bottom-color: #4a90d9;
}
.posts-expand .post-title-link:hover {
  color: #4a90d9;
}
.btn:hover {
  background: #4a90d9;
  border-color: #4a90d9;
}
.tag-cloud a:hover {
  color: #4a90d9 !important;
}

/* --- 选中文字 --- */
::selection {
  background: #4a90d9;
  color: #fff;
}

/* --- 卡片微调 --- */
.post-block {
  border-radius: 8px;
}

/* --- 行内代码 --- */
code {
  color: #4a90d9;
  background: rgba(74, 144, 217, 0.08);
  border-radius: 4px;
  padding: 2px 6px;
}

/* --- 引用块 --- */
blockquote {
  border-left-color: #4a90d9;
}

/* --- 表格表头 --- */
th {
  background: #4a90d9;
  color: #fff;
}
