/* ========================================
   黑白极简风格
   字体: 霞鹜文楷 + Fira Code
   ======================================== */

/* --- 霞鹜文楷字体 --- */
@import url('https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/style.css');

/* --- 页面背景灰黑渐变 --- */
body {
  font-family: "LXGW WenKai", "PingFang SC", "Microsoft YaHei", sans-serif;
  background: linear-gradient(180deg, #f0f0f0 0%, #e8e8e8 15%, #ffffff 40%);
  background-attachment: fixed;
}

/* --- 暗色模式下渐变 --- */
[data-theme="dark"] body {
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 30%, #0f0f23 100%);
  background-attachment: fixed;
}

/* --- 代码保持等宽 --- */
code, pre, .highlight {
  font-family: "Fira Code", "Cascadia Code", "Consolas", "Courier New", monospace;
}

/* --- 卡片微调 --- */
.post-block {
  border-radius: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  transition: box-shadow 0.3s ease;
}

.post-block:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}

/* --- 侧边栏卡片 --- */
.sidebar-inner .sidebar-nav,
.sidebar-inner .sidebar-panel,
.links-of-blogroll,
.links-of-author {
  border-radius: 10px;
}

/* --- 文章标题 --- */
.posts-expand .post-title {
  font-weight: 600;
}

.posts-expand .post-title-link {
  transition: color 0.2s ease;
}

/* --- 分割线 --- */
hr {
  background: linear-gradient(90deg, transparent, #ddd, #ddd, transparent);
  height: 1px;
  border: none;
}

/* --- 图片圆角 --- */
.post-body img {
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

/* --- 行内代码 --- */
code {
  border-radius: 4px;
  padding: 2px 6px;
}

/* ========================================
   侧边栏定制样式
   ======================================== */

/* --- 隐藏顶部菜单栏 --- */
.header-inner .menu,
.site-nav,
.site-nav-toggle,
.menu-item {
  display: none !important;
}

/* --- 隐藏原始侧边栏的所有内容，只保留自定义的 --- */
.site-overview-wrap > *:not(.custom-sidebar-wrap) {
  display: none !important;
}

/* --- 顶部标题区只显示副标题大字体 --- */
.site-title {
  display: none !important;
}

.site-subtitle {
  font-size: 20px !important;
  font-weight: 600;
  text-align: center;
  line-height: 1.6;
}

/* --- 顶部黑色区域 --- */
.header {
  background: #222 !important;
}

.header-inner {
  background: #222 !important;
  padding: 30px 0 !important;
}

.site-meta {
  background: #222 !important;
}

.header .site-subtitle {
  color: #ccc !important;
}

/* --- 侧边栏菜单 --- */
.sidebar-menu {
  margin-top: 16px;
  padding: 12px 0;
  border-top: 1px solid #eee;
  border-bottom: 1px solid #eee;
}

.sidebar-menu a {
  display: block;
  padding: 8px 16px;
  color: #555;
  font-size: 15px;
  text-decoration: none;
  transition: all 0.2s ease;
  border-radius: 6px;
  margin: 2px 0;
}

.sidebar-menu a:hover {
  background: #f5f5f5;
  color: #222;
}

[data-theme="dark"] .sidebar-menu {
  border-color: #333;
}

[data-theme="dark"] .sidebar-menu a:hover {
  background: #2a2a2a;
  color: #ddd;
}

/* --- 自定义简介 --- */
.custom-bio {
  padding: 8px 0 4px;
  font-size: 13px;
  color: #888;
  line-height: 1.7;
  text-align: center;
}

[data-theme="dark"] .custom-bio {
  color: #999;
}
