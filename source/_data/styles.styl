/* ========================================
   黑白极简风格
   字体: 霞鹜文楷 + Fira Code
   ======================================== */

/* --- 霞鹜文楷字体 --- */
@import url('https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/style.css');

/* --- 页面背景灰黑渐变 --- */
body {
  font-family: "LXGW WenKai", "PingFang SC", "Microsoft YaHei", sans-serif;
  background: linear-gradient(180deg, #f0f0f0 0%, #e8e8e8 15%, #ffffff 40%);
  background-attachment: fixed;
}

/* --- 暗色模式下渐变 --- */
[data-theme="dark"] body {
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 30%, #0f0f23 100%);
  background-attachment: fixed;
}

/* --- 代码保持等宽 --- */
code, pre, .highlight {
  font-family: "Fira Code", "Cascadia Code", "Consolas", "Courier New", monospace;
}

/* --- 头像强制正方形+圆形 --- */
.site-author-image {
  width: 100px !important;
  height: 100px !important;
  border-radius: 50% !important;
  object-fit: cover;
}

/* --- 隐藏日志/分类/标签统计 --- */
.site-state-wrap {
  display: none !important;
}

/* --- 卡片微调 --- */
.post-block {
  border-radius: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  transition: box-shadow 0.3s ease;
}

.post-block:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}

/* --- 侧边栏卡片 --- */
.sidebar-inner .sidebar-nav,
.sidebar-inner .sidebar-panel,
.links-of-blogroll,
.links-of-author {
  border-radius: 10px;
}

/* --- 文章标题 --- */
.posts-expand .post-title {
  font-weight: 600;
}

.posts-expand .post-title-link {
  transition: color 0.2s ease;
}

/* --- 分割线 --- */
hr {
  background: linear-gradient(90deg, transparent, #ddd, #ddd, transparent);
  height: 1px;
  border: none;
}

/* --- 图片圆角 --- */
.post-body img {
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

/* --- 行内代码 --- */
code {
  border-radius: 4px;
  padding: 2px 6px;
}

/* ========================================
   侧边栏定制样式
   ======================================== */

/* --- 顶部标题：大字显示副标题内容 --- */
.site-title {
  font-size: 22px !important;
  font-weight: 600;
  line-height: 1.8;
  text-align: center;
}

.site-subtitle {
  display: none !important;
}

/* --- 顶部黑色区域 --- */
.header {
  background: #222 !important;
}

.header-inner {
  background: #222 !important;
  padding: 25px 0 !important;
}

.site-meta {
  background: #222 !important;
}

.header .site-title,
.header .site-title a {
  color: #ddd !important;
}

/* --- 侧边栏标签：站点概览在左，文章目录在右 --- */
.sidebar-nav {
  display: flex !important;
  flex-direction: row !important;
  width: 100% !important;
}

.sidebar-nav-overview {
  order: 1 !important;
}

.sidebar-nav-toc {
  order: 2 !important;
  margin-left: auto !important;
}

/* --- 侧边栏菜单 --- */
.sidebar-menu {
  margin-top: 16px;
  padding: 12px 0;
  border-top: 1px solid #eee;
  border-bottom: 1px solid #eee;
}

.sidebar-menu a {
  display: block;
  padding: 8px 16px;
  color: #555;
  font-size: 15px;
  text-decoration: none;
  transition: all 0.2s ease;
  border-radius: 6px;
  margin: 2px 0;
}

.sidebar-menu a:hover {
  background: #f5f5f5;
  color: #222;
}

[data-theme="dark"] .sidebar-menu {
  border-color: #333;
}

[data-theme="dark"] .sidebar-menu a:hover {
  background: #2a2a2a;
  color: #ddd;
}

