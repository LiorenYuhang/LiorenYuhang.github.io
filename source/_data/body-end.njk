<script src="/js/click-effect.js"></script>
<script>
// 把顶部菜单移到侧边栏-社交链接之前
(function() {
  var menu = document.querySelector('.site-nav');
  var overview = document.querySelector('.site-overview-wrap');
  if (menu && overview) {
    menu.classList.add('sidebar-menu');
    // 菜单插到社交链接之前（统计已隐藏，直接找社交链接）
    var social = overview.querySelector('.links-of-author');
    if (social) {
      social.before(menu);
    } else {
      overview.appendChild(menu);
    }
  }
})();
</script>

<script>
// 邮箱点击复制到剪贴板
(function() {
  var emailLink = document.querySelector('.links-of-author-item a[href^="mailto:"]');
  if (!emailLink) return;

  // 归档页标语
  (function() {
    if (!window.location.pathname.includes('/archives')) return;
    var header = document.querySelector('.collection-header');
    if (header) header.textContent = '记录思考，对抗遗忘。';
  })();

  // 关于页面隐藏侧边栏标签区
  (function() {
    if (!window.location.pathname.includes('/about')) return;
    var sidebar = document.querySelector('.sidebar');
    if (!sidebar) return;
    // 隐藏所有标签按钮和面板，直接显示站点概览内容
    var nav = sidebar.querySelector('.sidebar-nav');
    var toc = sidebar.querySelector('.sidebar-panel-toc');
    var overview = sidebar.querySelector('.sidebar-panel-overview');
    if (nav) nav.style.display = 'none';
    if (toc) toc.style.display = 'none';
    if (overview) overview.style.display = 'block';
  })();
  var email = emailLink.getAttribute('href').replace('mailto:', '');
  var item = emailLink.closest('.links-of-author-item');

  emailLink.addEventListener('click', function(e) {
    e.preventDefault();
    navigator.clipboard.writeText(email).then(function() {
      var toast = document.createElement('span');
      toast.className = 'email-copied-toast';
      toast.textContent = '已复制';
      item.style.position = 'relative';
      item.appendChild(toast);
      setTimeout(function() { toast.remove(); }, 5000);
    });
  });
})();
</script>
